{
  "title": "", // required; type: string; description: Bad Request
  "status": 0, // required; type: integer; format: int32; description: 400
  "instance": "", // required; type: string; description: URI identyfikujące konkretne wystąpienie błędu.
  "detail": "", // required; type: string; description: Ogólny opis problemu.
  "errors": [ // required; type: array; description: Lista błędów powiązanych z żądaniem.
    {
      "code": 0, // required; type: integer; format: int32; description: Kod błędu.
      "description": "", // required; type: string; description: Ogólny opis błędu odpowiadający danemu kodowi.
      "details": [ // type: array; nullable: true; description: Lista szczegółowych komunikatów opisujących konkretny błąd.
Może zawierać wiele wpisów dla jednego kodu błędu.
      ]
    }
  ],
